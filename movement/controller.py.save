from config.settings import USE_PI

if USE_PI:
    from gpiozero import DigitalOutputDevice, PWMOutputDevice


class MovementController:
    def __init__(self):
        if USE_PI:
            print("Initializing 4 independent motors")

            # ===== LEFT FRONT =====
            self.LF_IN1 = DigitalOutputDevice(17)
            self.LF_IN2 = DigitalOutputDevice(27)
            self.LF_PWM = PWMOutputDevice(18)

            # ===== LEFT REAR =====
            self.LR_IN1 = DigitalOutputDevice(22)
            self.LR_IN2 = DigitalOutputDevice(23)
            self.LR_PWM = PWMOutputDevice(19)

            # ===== RIGHT FRONT =====
            self.RF_IN1 = DigitalOutputDevice(13)
            self.RF_IN2 = DigitalOutputDevice(6)
            self.RF_PWM = PWMOutputDevice(12) # UNCOMMENT IF NEEDED

            # ===== RIGHT REAR =====
            self.RR_IN1 = DigitalOutputDevice(20)
            self.RR_IN2 = DigitalOutputDevice(21)
            self.RR_PWM = PWMOutputDevice(16)

            # Standby
            self.L_STBY = DigitalOutputDevice(5)
            self.R_STBY = DigitalOutputDevice(26)

            self.L_STBY.on()
            self.R_STBY.on()

    def _normalize(self, speed):
        return max(0, min(speed, 100)) / 100

    def _set_motor(self, in1, in2, pwm, forward, speed):
        if forward:
            in1.on()
            in2.off()
        else:
            in1.off()
            in2.on()
        pwm.value = self._normalize(speed)

    def move_forward(self, speed=60):
        print("[MOVEMENT] Forward")

        self._set_motor(self.LF_IN1, self.LF_IN2, self.LF_PWM, True, speed)
        self._set_motor(self.LR_IN1, self.LR_IN2, self.LR_PWM, True, speed)
        self._set_motor(self.RF_IN1, self.RF_IN2, self.RF_PWM, True, speed)
        self._set_motor(self.RR_IN1, self.RR_IN2, self.RR_PWM, True, speed)

    def move_backward(self, speed=60):
        print("[MOVEMENT] Backward")

        self._set_motor(self.LF_IN1, self.LF_IN2, self.LF_PWM, False, speed)
        self._set_motor(self.LR_IN1, self.LR_IN2, self.LR_PWM, False, speed)
        self._set_motor(self.RF_IN1, self.RF_IN2, self.RF_PWM, False, speed)
        self._set_motor(self.RR_IN1, self.RR_IN2, self.RR_PWM, False, speed)

    def turn_left(self, speed=60):
        print("[MOVEMENT] Left")

        # Left backward, right forward
        self._set_motor(self.LF_IN1, self.LF_IN2, self.LF_PWM, False, speed)
        self._set_motor(self.LR_IN1, self.LR_IN2, self.LR_PWM, False, speed)
        self._set_motor(self.RF_IN1, self.RF_IN2, self.RF_PWM, True, speed)
        self._set_motor(self.RR_IN1, self.RR_IN2, self.RR_PWM, True, speed)

    def turn_right(self, speed=60):
        print("[MOVEMENT] Right")

        self._set_motor(self.LF_IN1, self.LF_IN2, self.LF_PWM, True, speed)
        self._set_motor(self.LR_IN1, self.LR_IN2, self.LR_PWM, True, speed)
        self._set_motor(self.RF_IN1, self.RF_IN2, self.RF_PWM, False, speed)
        self._set_motor(self.RR_IN1, self.RR_IN2, self.RR_PWM, False, speed)

    def stop(self):
        print("[MOVEMENT] Stop")

        self.LF_PWM.value = 0
        self.LR_PWM.value = 0
        self.RF_PWM.value = 0
        self.RR_PWM.value = 0
        
    
def cleanup(self):
        self.stop()
        self.L_STBY.off()
        self.R_STBY.off()
